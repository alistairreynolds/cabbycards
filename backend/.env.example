# Copy to .env and adjust. The .env file is git-ignored.
#
# REQUIRED keys (no default — must be set) are in the first block.
# The rest have safe defaults in app/core/config.py and are shown here only so
# you know they exist / can override them.

# ============================================================
# REQUIRED — must be set per environment
# ============================================================

# Async SQLAlchemy DSN (note the +asyncpg driver). Port 5433 matches docker-compose.
DATABASE_URL=postgresql+asyncpg://cabbycards:cabbycards@localhost:5433/cabbycards

# Session JWT signing secret. Generate a long random value (>=32 bytes) for real use:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me-please-0123456789

# Cloudflare Turnstile secret (bot protection on registration). The value below is
# Cloudflare's documented ALWAYS-PASSES test secret — fine for dev/CI. Use your real
# secret key in production.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ============================================================
# OPTIONAL — safe defaults exist in code; override if needed
# ============================================================

# SCRYFALL_BASE_URL=https://api.scryfall.com
# Scryfall asks for a descriptive User-Agent identifying your app/contact.
# SCRYFALL_USER_AGENT=CabbyCards/0.1 (+https://github.com/alistairreynolds/cabbycards)
# CARD_CACHE_TTL_DAYS=14

# TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# email_backend: "console" logs the message (dev). SMTP backend lands later (no AWS/SES).
# EMAIL_BACKEND=console
# EMAIL_FROM=CabbyCards <no-reply@cabbycards.local>
# FRONTEND_BASE_URL=http://localhost:5173   # used to build email verification links

# JWT_ALGORITHM=HS256
# JWT_EXPIRY_MINUTES=43200
