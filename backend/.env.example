# Copy to .env and adjust. The .env file is git-ignored.

# Async SQLAlchemy DSN (note the +asyncpg driver). Port 5433 matches docker-compose.
DATABASE_URL=postgresql+asyncpg://cabbycards:cabbycards@localhost:5433/cabbycards

# Scryfall politely requires a descriptive User-Agent and an explicit Accept header.
# See https://scryfall.com/docs/api — use your own contact/app identifier here.
SCRYFALL_BASE_URL=https://api.scryfall.com
SCRYFALL_USER_AGENT=CabbyCards/0.1 (+https://github.com/your-account/cabbycards)

# Days before a cached card is considered stale and re-fetched on next access.
CARD_CACHE_TTL_DAYS=14

# Session JWT signing (used by the auth slice). Generate a long random secret for real use.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=43200
